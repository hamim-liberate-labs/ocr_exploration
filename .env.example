# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values. `.env` is git-ignored.
# -----------------------------------------------------------------------------

# Google Gemini API key (google-genai, API-key mode).
# NOTE: the §8 LLM-judge in experiments/ovisocr2_vs_vl/ uses Vertex AI
# (service-account auth) instead — see vertex-service-account.json below.
# This key is only needed if you switch the judge to the public Gemini API.
GOOGLE_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# Modal OCR endpoints (client-side, used by modal_deploy/test_client.py)
# -----------------------------------------------------------------------------
# Base URL of the deployed Modal OCR app.
OCR_URL=https://<your-workspace>--<app-name>.modal.run

# Bearer token for the PaddleOCR-VL 1.6 OCR endpoint (modal_deploy/modal_app.py).
OCR_TOKEN=your-paddleocr-vl16-endpoint-token

# Bearer token for the OvisOCR2 endpoint (modal_deploy/ovisocr2_app.py).
OVISOCR2_TOKEN=your-ovisocr2-endpoint-token
